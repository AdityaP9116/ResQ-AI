                    token[] semantics:labels:class = ["fire"]
                    float3 xformOp:rotateXYZ = (0, 0, 0)
                    float3 xformOp:scale = (1, 1, 1)
                    double3 xformOp:translate = (0.8999999999999999, 0.6, 9.7)
                    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
                }
            }
        }
    }

    def Xform "Lights"
    {
        float3 xformOp:rotateXYZ = (0, 0, 0)
        float3 xformOp:scale = (1, 1, 1)
        double3 xformOp:translate = (0, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]

        def DomeLight "Sky"
        {
            color3f inputs:color = (0.85, 0.92, 1)
            float inputs:intensity = 1200
            asset inputs:texture:file = @https://omniverse-content-production.s3-us-west-2.amazonaws.com/Assets/Isaac/5.1/NVIDIA/Assets/Skies/Clear/noon_grass_4k.hdr@
        }

        def Xform "Sun"
        {
            float3 xformOp:rotateXYZ = (-50, 25, 0)
            double3 xformOp:translate = (0, 0, 120)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]

            def DistantLight "Light"
            {
                float inputs:angle = 0.53
                color3f inputs:color = (1, 0.94, 0.82)
                float inputs:intensity = 4500
            }
        }

        def RectLight "FillLight"
        {
            color3f inputs:color = (0.7, 0.8, 1)
            float inputs:height = 80
            float inputs:intensity = 300
            float inputs:width = 80
            float3 xformOp:rotateXYZ = (-90, 0, 0)
            float3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (0, 0, 60)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
        }
    }

    def PhysicsScene "PhysicsScene" (
        prepend apiSchemas = ["PhysxSceneAPI"]
    )
    {
        vector3f physics:gravityDirection = (0, 0, -1)
        float physics:gravityMagnitude = 9.81
    }

    def Xform "GroundCollider" (
        prepend apiSchemas = ["PhysicsCollisionAPI"]
    )
    {
        custom token physics:approximation = "none"
        float3 xformOp:rotateXYZ = (0, 0, 0)
        float3 xformOp:scale = (1, 1, 1)
        double3 xformOp:translate = (0, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]

        def Cube "Plane" (
            prepend apiSchemas = ["PhysicsCollisionAPI"]
        )
        {
            double size = 1
            float3 xformOp:rotateXYZ = (0, 0, 0)
            float3 xformOp:scale = (500, 500, 1)
            double3 xformOp:translate = (0, 0, -0.5)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
        }
    }
}


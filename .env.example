# ============================================================================
# ResQ-AI Environment Configuration Template
#
# Copy this file to .env and customize for your setup:
#   cp .env.example .env
#
# Then edit values to match your system
# ============================================================================

# ============================================================================
# Isaac Sim Configuration
# ============================================================================

# Path to Isaac Sim installation
# Default: ~/.local/share/ov/pkg/isaac-sim-5.1 (if installed via Launcher)
# Or: /workspace/isaac-sim (if using Docker)
ISAAC_SIM_PATH=~/.local/share/ov/pkg/isaac-sim-5.1

# Isaac Sim Python executable (auto-detected if not set)
# Leave blank to auto-detect
ISAAC_SIM_PYTHON=

# Run in headless mode (no GUI) - recommended for servers
HEADLESS_MODE=false

# ============================================================================
# Simulation Configuration
# ============================================================================

# Camera resolution (WIDTHxHEIGHT)
# Larger = better quality but slower
# Try 640x480 (default), 480x360 (faster), 1280x720 (higher quality)
SCENE_RESOLUTION=1280x720

# Number of simulation steps per second
# Higher = more accurate but slower
SIMULATION_PHYSICS_DT=0.016667

# Maximum number of investigation points in demo flight
MAX_INVESTIGATIONS=5

# ============================================================================
# Output Paths
# ============================================================================

# Root directory for all outputs
OUTPUT_DIR=./outputs

# YOLO model weights location
YOLO_WEIGHTS_PATH=./Phase1_SituationalAwareness/best.pt

# Asset packs root directory
ASSET_ROOT_PATH=./assets

# ============================================================================
# Vision-Language Model (VLM) Configuration
# ============================================================================

# Backend selection: mock | nim | vllm
# - mock: Deterministic, no GPU, fast responses (good for testing)
# - nim: NVIDIA NIM cloud API (requires NVIDIA_API_KEY)
# - vllm: Local self-hosted Cosmos model (requires GPU, slow on first run)
VLM_BACKEND=mock

# VLM Server host and port
VLM_SERVER_HOST=0.0.0.0
VLM_SERVER_PORT=8000

# VLM Server timeout (seconds)
VLM_SERVER_TIMEOUT=30

# ============================================================================
# VLM Backend: NVIDIA API (NIM)
# ============================================================================

# NVIDIA API Key (get from https://build.nvidia.com/)
# Required for --backend nim
NVIDIA_API_KEY=

# NVIDIA API endpoint
NVIDIA_API_ENDPOINT=https://api.nvcf.nvidia.com/execute/v1/rag

# ============================================================================
# VLM Backend: Local vLLM
# ============================================================================

# Model ID for local vLLM backend
# Example: nvidia/Cosmos-1.0-Reasoning-7.5B
VLLM_MODEL_ID=

# Number of GPUs for tensor parallelism (vLLM)
VLLM_TENSOR_PARALLEL_SIZE=1

# vLLM server port
VLLM_SERVER_PORT=8001

# ============================================================================
# NVIDIA GPU Configuration
# ============================================================================

# GPU device IDs to use (comma-separated)
# Leave empty to use all available GPUs
# Examples: 0 (first GPU), 0,1 (first and second GPU)
CUDA_VISIBLE_DEVICES=

# NVIDIA driver capabilities
# graphics = for UI/visualization
# compute,utility = for headless computation
NVIDIA_DRIVER_CAPABILITIES=compute,utility,graphics

# ============================================================================
# Python & Development Configuration
# ============================================================================

# Python version to use
PYTHON_VERSION=3.10

# Virtual environment path (if using local setup)
VENV_PATH=./isaac_env

# Add to Python path (for imports)
PYTHONPATH=./

# Prevent Python bytecode caching
PYTHONDONTWRITEBYTECODE=1

# ============================================================================
# Logging & Debugging
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Save detailed logs to file
SAVE_LOGS=true

# Log directory
LOGS_DIR=./logs

# Enable debug mode (verbose output)
DEBUG_MODE=false

# Save frame-by-frame analysis
SAVE_FRAME_ANALYSIS=false

# ============================================================================
# Performance Tuning
# ============================================================================

# Batch size for inference (lower = less memory, slower inference)
BATCH_SIZE=1

# Process every Nth frame for inference (1 = every frame, 2 = every 2nd, etc)
INFERENCE_SKIP_FRAMES=1

# Enable GPU memory optimization
GPU_MEMORY_FRACTION=0.8

# Enable mixed precision (faster, less precise)
MIXED_PRECISION=true

# ============================================================================
# Data & Files
# ============================================================================

# Random seed for reproducibility
RANDOM_SEED=42

# Maximum frames to process in a simulation
MAX_SIMULATION_FRAMES=0  # 0 = unlimited

# Save annotated video output
SAVE_VIDEO=true

# Video codec (h264, h265, avi, etc)
VIDEO_CODEC=h264

# ============================================================================
# Docker Configuration
# ============================================================================

# Docker image name
DOCKER_IMAGE=resq-ai:latest

# Docker container name
DOCKER_CONTAINER=resq-ai-sim

# Volume mounts (Docker)
# Format: /host/path:/container/path
DOCKER_VOLUMES=-v $(pwd):/workspace/resq-ai

# ============================================================================
# Network Configuration (for VLM server)
# ============================================================================

# Allow external connections to VLM server
ALLOW_EXTERNAL_CONNECTIONS=false

# Client timeout for VLM calls (seconds)
CLIENT_TIMEOUT=10

# Number of retries for VLM calls
VLM_RETRY_ATTEMPTS=3

# ============================================================================
# Optional: Additional Paths and Settings
# ============================================================================

# Path to pre-generated USD scene (optional)
# If not set, scene will be generated on-the-fly
USD_SCENE_PATH=

# Path to custom terrain/map (optional)
CUSTOM_TERRAIN_PATH=

# Email for notifications (optional)
NOTIFICATION_EMAIL=

# ============================================================================
# Notes
# ============================================================================
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Edit the .env file with your specific values
#
# 3. Load environment variables in bash:
#    source .env
#
# 4. Load in Python:
#    from dotenv import load_dotenv
#    load_dotenv()
#
# 5. Access in Python:
#    import os
#    isaac_path = os.getenv("ISAAC_SIM_PATH")
#
# 6. For Docker, pass as:
#    docker run --env-file .env resq-ai:latest
#
# ============================================================================

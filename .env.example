# ResQ-AI Environment Configuration
# Copy this to .env and fill in your values.

# ─── Cosmos Reason 2 ─────────────────────────────────────────────────────
# Get your API key from: https://build.nvidia.com/settings/api-keys
# Required only when running: python orchestrator/vlm_server.py --backend nim
NVIDIA_API_KEY=nvapi-PASTE_YOUR_KEY_HERE

# VLM backend: "mock" (no GPU), "nim" (NVIDIA cloud), "vllm" (local)
RESQAI_VLM_BACKEND=mock

# If using local vLLM server (--backend vllm), set its URL:
# Start vLLM first: vllm serve nvidia/Cosmos-Reason2-2B --port 8001
RESQAI_VLLM_URL=http://localhost:8001

# Model name (for nim / vllm backends)
RESQAI_COSMOS_MODEL=nvidia/cosmos-reason2-2b

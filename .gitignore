*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── Virtual Environments ───────────────────────────────
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
isaac_env/
isaacsim_env/

# ── IDEs ───────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.gemini/

# ── OS ─────────────────────────────────────────────────
